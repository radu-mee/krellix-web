{
  "$schema": "./node_modules/wrangler/config-schema.json",
  "name": "krellix-website",
  "workers_dev": true,
  "preview_urls": false,
  "main": ".open-next/worker.js",
  "compatibility_date": "2026-04-15",
  "compatibility_flags": [
    "nodejs_compat"
  ],
  "assets": {
    "directory": ".open-next/assets",
    "binding": "ASSETS"
  },
  "observability": {
    "logs": {
      "enabled": true
    }
  }
}
